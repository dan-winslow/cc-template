---
layout: layouts/base.njk
title: Comedian Bio Portal
permalink: /bio-portal/index.html
---

<section class="page-head">
    <h1>Comedian Bio Portal</h1>
    <p>Share an individual update link with each comedian, manager, or publicist.</p>
</section>
<section class="panel">
    <div class="cards two-up">
        {% for comic in comedians.items %}
            {% set comicSlug = (comic.slug or comic.name) | slugify %}
            {% set generatedSubmissionLink = (site.bioSubmissionBaseUrl and (site.bioSubmissionBaseUrl ~ '?comedian=' ~ comicSlug)) or '' %}
            {% set submissionLink = comic.bioUpdateUrl or generatedSubmissionLink %}
            {% set draftToken = comic.bioDraftToken or ((comicSlug ~ '-draft-' ~ (comic.date or '')) | slugify) %}
            {% set draftPreviewLink = (comic.bioStatus == 'pending' and comic.pendingBio and ('/comedians/' ~ comicSlug ~ '/?draft=' ~ draftToken)) or '' %}
            <article class="card">
                <p class="eyebrow">Status: {{ comic.bioStatus or 'approved' }}</p>
                <h2>{{ comic.name }}</h2>
                <p class="muted">Share URL: /{{ comicSlug }}</p>
                {% if submissionLink %}
                    <p class="link-actions">
                        <a class="button"
                           href="{{ submissionLink }}"
                           target="_blank"
                           rel="noopener noreferrer">Open Bio Submission Link</a>
                        <button class="button ghost"
                                type="button"
                                data-copy-link
                                data-copy-value="{{ submissionLink }}"
                                data-copy-label="Bio submission link">Copy Link</button>
                    </p>
                    <p class="muted copy-status" data-copy-status hidden></p>
                    <p class="muted">Auto-generated from Site Settings unless Bio Update Link override is set.</p>
                {% else %}
                    <p class="muted">Set Site Settings -> Bio Submission Base URL to auto-generate manager/publicist update links.</p>
                {% endif %}
                {% if comic.bioStatus == 'pending' and comic.pendingBio %}
                    <p><strong>Pending Draft Preview:</strong> {{ comic.pendingBio }}</p>
                    {% if draftPreviewLink %}
                        <p class="link-actions">
                            <a class="button ghost"
                               href="{{ draftPreviewLink }}"
                               target="_blank"
                               rel="noopener noreferrer">Open Private Draft Preview</a>
                            <button class="button ghost"
                                    type="button"
                                    data-copy-link
                                    data-copy-value="{{ draftPreviewLink }}"
                                    data-copy-label="Private draft link">Copy Link</button>
                        </p>
                        <p class="muted copy-status" data-copy-status hidden></p>
                        <p class="muted">Anyone with this link can view the pending draft preview.</p>
                    {% endif %}
                {% endif %}
                <p>
                    <a class="text-link" href="/comedians/{{ comicSlug }}/">Open Club Profile</a>
                </p>
            </article>
        {% endfor %}
    </div>
</section>
<script>
    (() => {
        const copyButtons = Array.from(document.querySelectorAll('[data-copy-link]'));
        if (!copyButtons.length) {
            return;
        }

        const toAbsoluteUrl = (value) => {
            try {
                return new URL(value, window.location.origin).toString();
            } catch (_error) {
                return value;
            }
        };

        const setStatus = (button, message) => {
            const card = button.closest('.card');
            if (!card) {
                return;
            }
            const status = card.querySelector('[data-copy-status]');
            if (!status) {
                return;
            }
            status.hidden = false;
            status.textContent = message;
            window.setTimeout(() => {
                status.hidden = true;
                status.textContent = '';
            }, 2400);
        };

        const copyText = async (value) => {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(value);
                return;
            }

            const temp = document.createElement('textarea');
            temp.value = value;
            temp.setAttribute('readonly', 'true');
            temp.style.position = 'absolute';
            temp.style.left = '-9999px';
            document.body.appendChild(temp);
            temp.select();
            document.execCommand('copy');
            document.body.removeChild(temp);
        };

        copyButtons.forEach((button) => {
            button.addEventListener('click', async () => {
                const value = button.getAttribute('data-copy-value') || '';
                const label = button.getAttribute('data-copy-label') || 'Link';
                if (!value) {
                    setStatus(button, `${label} is unavailable.`);
                    return;
                }
                try {
                    await copyText(toAbsoluteUrl(value));
                    setStatus(button, `${label} copied.`);
                } catch (_error) {
                    setStatus(button, `Unable to copy ${label.toLowerCase()}.`);
                }
            });
        });
    })();
</script>
