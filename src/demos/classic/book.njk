---
layout: layouts/base.njk
title: Contact and Book
permalink: /demos/classic/book/index.html
---

<section class="page-head">
    <h1>Contact + Book an Event</h1>
    <p>Use this page for private bookings, touring inquiries, and sponsor nights.</p>
</section>
<section class="cards three-up">
    {% for pkg in booking.packages %}
        <article class="card">
            <h2>{{ pkg.name }}</h2>
            <p>{{ pkg.description }}</p>
            <p class="price">Starting at {{ pkg.startingPrice }}</p>
            <p class="muted">Capacity: {{ pkg.capacity }}</p>
        </article>
    {% endfor %}
</section>
<section class="panel split">
    <div>
        <h2>Venue Contact</h2>
        <p>{{ site.clubName }}</p>
        <p>{{ site.address }}</p>
        <p>{{ site.phone }}</p>
        <p><a class="text-link" href="mailto:{{ site.email }}">{{ site.email }}</a></p>
    </div>
    <form class="inquiry-form"
          name="booking-inquiry"
          method="post"
          data-netlify="true">
        <input type="hidden" name="form-name" value="booking-inquiry" />
        <label>
            Name
            <input type="text" name="name" required />
        </label>
        <label>
            Email
            <input type="email" name="email" required />
        </label>
        <label>
            Event Date
            <input type="date" name="eventDate" />
        </label>
        <label>
            Message
            <textarea name="message" rows="4"></textarea>
        </label>
        <button class="button" type="submit">Send Inquiry</button>
    </form>
</section>
